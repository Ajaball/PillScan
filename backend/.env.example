# PillScan Backend Configuration
# Copy this file to .env and fill in your values

# App
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://pillscan:pillscan_password@localhost:5432/pillscan_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=dev-secret-key-change-in-production-1234567890abcdef

# Admin account — seeded automatically on startup (role=ADMIN, status=APPROVED)
# if no user with ADMIN_EMAIL exists yet. Change these in production!
ADMIN_EMAIL=admin@pillscan.com
ADMIN_PHONE=+966500000000
ADMIN_PASSWORD=admin123
# Set to false to disable the automatic admin/drug seeding on startup.
SEED_ON_STARTUP=true

# Vision LLM (Google Gemini) — powers pill identification and the Arabic
# leaflet summary. The app is Gemini-only. Users can add their own keys in the
# app (AI settings); these server keys are an optional shared fallback.
# Up to five keys are tried in order — when one is exhausted (quota/rate-limit)
# or fails, the next is used automatically.
# GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

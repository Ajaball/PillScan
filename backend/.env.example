# PillScan Backend Configuration
# Copy this file to .env and fill in your values

# App
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://pillscan:pillscan_password@localhost:5432/pillscan_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=dev-secret-key-change-in-production-1234567890abcdef

# Pill Identification & Leaflet Summarizer (Vision LLM) — both pill scanning
# and leaflet/prescription summarization run entirely on a vision LLM.
# Choose ONE provider and set its key.
LLM_PROVIDER=gemini
# Google Gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OpenAI (ChatGPT) — set LLM_PROVIDER=openai to use these
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# PillScan Backend Configuration
# Copy this file to .env and fill in your values

# App
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://pillscan:pillscan_password@localhost:5432/pillscan_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=dev-secret-key-change-in-production-1234567890abcdef

# AI Service
AI_SERVICE_URL=http://localhost:8001
# Pill scan strategy: CV model first, then vision-LLM fallback.
# Set to false to skip the local CV model and identify via the LLM only
# (useful while the classifier model is being retrained).
SCAN_AI_MODEL_ENABLED=true
SCAN_LLM_FALLBACK_ENABLED=true

# Leaflet Summarizer (Vision LLM) — reads a leaflet/prescription photo and
# returns an Arabic summary. Choose ONE provider and set its key.
LLM_PROVIDER=gemini
# Google Gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# OpenAI (ChatGPT) — set LLM_PROVIDER=openai to use these
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
